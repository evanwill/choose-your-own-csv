---
/**
 * index.astro — home page
 *
 * Lists all configured stories so readers can choose where to begin.
 * In development mode, also shows a form that lets anyone load an
 * arbitrary CSV by pasting its URL.
 */
import Layout from '../layouts/Layout.astro';
import { siteTitle, siteDescription, siteFooter, stories, developmentMode } from '../config.js';

// Base URL used to build links that work for both root and subdirectory deploys.
// Normalized to always have a trailing slash so path concatenation works correctly.
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<Layout title="">
  <div class="container">

    <!-- Site introduction -->
    <section class="home-intro">
      <h1>{siteTitle}</h1>
      <p>{siteDescription}</p>
      <p><a href="about/">Learn more</a> or <a href="get-started/">Create your own story</a>!</p>
    </section>

    <!-- Story list -->
    {stories.length > 0 ? (
      <section>
        <h2>Stories</h2>
        <ul class="story-list">
          {stories.map(story => (
            <li class="story-card">
              <!-- Links to /story/?story=<id>, which the story page reads at runtime -->
              <a href={`${base}story/?story=${story.id}`}>{story.title}</a>
              {story.description && <p>{story.description}</p>}
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <p>No stories configured yet. Edit <code>src/config.js</code> to add one!</p>
    )}

    <!-- Development-mode CSV loader ------------------------------------------
         Only rendered when developmentMode is true. Lets collaborators paste
         any CSV URL and jump straight into the story player without touching
         the config.
    -------------------------------------------------------------------------->
    {developmentMode && (
      <div class="dev-form">
        <h2>Development Mode — Test and Share any CSV</h2>
        <p>
          Paste the URL of any CSV that follows the
          <a href={`${base}docs/spreadsheet_setup.md`}>spreadsheet format</a>
          to preview it as a story. This form is only visible when
          <code>developmentMode</code> is <code>true</code> in
          <code>src/config.js</code>.
        </p>
        <form id="dev-csv-form">
          <input
            type="url"
            id="dev-csv-url"
            name="csv"
            placeholder="https://docs.google.com/spreadsheets/d/…/pub?output=csv"
            required
          />
          <button type="submit" class="btn">Load Story</button>
        </form>
      </div>
    )}

  </div>

  <!-- Footer text -->
  <span slot="footer">{siteFooter}</span>
</Layout>

{/* Client-side script — only active when developmentMode === true */}
{developmentMode && (
  <script define:vars={{ base }}>
    const form = document.getElementById('dev-csv-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const url = (document.getElementById('dev-csv-url')).value.trim();
        if (url) {
          // Navigate to the story player with the CSV URL as a query param
          window.location.href = `${base}story/?csv=${encodeURIComponent(url)}`;
        }
      });
    }
  </script>
)}
